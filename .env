# ===================================================
# FRONTEND .env FILE (React + Vite)
# ===================================================

# 🌐 API Configuration
VITE_API_URL=http://localhost:5000

# 🎨 Application Configuration  
VITE_APP_NAME=TapIn
VITE_APP_DESCRIPTION="Professional Event Management Platform"

# 🔧 Development Configuration
VITE_NODE_ENV=development

# 🧪 Optional: AI Integration (for description generation)
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 📱 Optional: Analytics
# VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# 🌍 Optional: Production API URL (for deployment)
# VITE_PROD_API_URL=https://your-backend-domain.com

# ❌ REMOVED - No longer needed with JWT:
# VITE_CLERK_PUBLISHABLE_KEY=...
# VITE_RAZORPAY_KEY_ID=...
